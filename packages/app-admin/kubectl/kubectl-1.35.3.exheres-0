require go [ go_minimum_version=1.25.0 package_path=./cmd/kubectl ] github [ user=kubernetes pn=kubernetes tag=v${PV} ]

SUMMARY="Command-line tool for communicating with a Kubernetes cluster"
HOMEPAGE="https://kubernetes.io"

LICENCES="Apache-2.0"
SLOT="0"
PLATFORMS="~amd64 ~armv8"
MYOPTIONS=""

DEPENDENCIES=""

GO_SRC_COMPILE_LDFLAGS=(
    "-s"
    "-w"
)

